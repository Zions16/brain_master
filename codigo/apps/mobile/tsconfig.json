{
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "react-native",
    "noEmit": true,
    "baseUrl": ".",
    "lib": ["ES2020"],
    "target": "ES2020",
    "paths": {
      "@/*": ["./*"],
      "@brain-master/shared/*": ["../../packages/shared/*"],
      "@brain-master/validators": ["../../packages/validators/index.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": ["node_modules"]
}
