# API — Brain Master
# Copie este arquivo para .env e preencha os valores
# NUNCA commitar o .env com valores reais

# Supabase (backend — service key é privada, NUNCA expor no cliente)
SUPABASE_URL=https://[seu-projeto].supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Servidor
PORT=3333
NODE_ENV=development

# JWT — gerado com: openssl rand -hex 32
JWT_SECRET=troque-por-string-aleatoria-minimo-32-chars

# CORS — origens permitidas (separadas por vírgula)
# Staging: adicionar URL do Vercel preview
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# URL pública do dashboard web (usada em links de email)
APP_URL=https://brain-master-delta.vercel.app

# Sentry — monitoramento de erros em produção
# Obter em: https://sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=https://[chave]@o[org].ingest.sentry.io/[projeto]

# Resend — email transacional
# Obter em: https://resend.com → API Keys
RESEND_API_KEY=re_...
