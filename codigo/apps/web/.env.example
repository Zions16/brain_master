# Web — Brain Master (Next.js)
# Prefixo NEXT_PUBLIC_ expõe a variável no bundle do cliente
# NUNCA usar SERVICE_KEY com prefixo NEXT_PUBLIC_

NEXT_PUBLIC_SUPABASE_URL=https://[seu-projeto].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Se houver rotas de API server-side no Next.js:
SUPABASE_SERVICE_KEY=eyJ...
