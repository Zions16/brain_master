# Web — Brain Master (Next.js)
# Prefixo NEXT_PUBLIC_ expõe a variável no bundle do cliente
# NUNCA usar SERVICE_KEY com prefixo NEXT_PUBLIC_
# NUNCA colocar SUPABASE_SERVICE_KEY no web — fica SOMENTE na API

NEXT_PUBLIC_SUPABASE_URL=https://[seu-projeto].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# URL da API Fastify
# Desenvolvimento: http://localhost:3333
# Staging: https://[seu-servico].up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:3333

# Sentry — monitoramento de erros em produção
# DSN é público (NEXT_PUBLIC_) pois é enviado ao browser para capturar erros client-side
# Obter em: https://sentry.io → Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://[chave]@o[org].ingest.sentry.io/[projeto]

# Usados apenas no build para upload de source maps (não vão para o browser)
SENTRY_ORG=brain-master
SENTRY_PROJECT=brain-master-web
SENTRY_AUTH_TOKEN=sntrys_...
