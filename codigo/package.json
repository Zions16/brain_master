    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "ajv": "^8.20.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2",
    "turbo": "^2.9.14",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@types/react": "~18.3.12"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.8.1"
